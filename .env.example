# Contact form endpoint (Cloudflare Worker / API)
# Full HTTPS URL that receives POSTed JSON from the contact form
# E.g., VITE_CONTACT_ENDPOINT=https://orivenza-mail.ruchir031198.workers.dev
VITE_CONTACT_ENDPOINT=

# Contact mailbox shown in UI fallback links
VITE_CONTACT_EMAIL=get.info@orivenza.com

# GST demo public endpoint (handled by GST-AI-orivenza backend)
# Must accept POST multipart/form-data with fields:
# - "file": the uploaded document
# - "question": single user question
# and respond with JSON: { "answer": "..." }
VITE_GST_DEMO_ENDPOINT=

# Base path for subpath hosting (only if not using a custom domain)
# E.g., VITE_BASE=/orivenza-site/ for GitHub Pages project site
# Leave blank or set to / for root domain or custom domain
VITE_BASE=/
