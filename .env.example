# Contact / lead intake endpoint hosted on AWS
# E.g., VITE_CONTACT_ENDPOINT=https://api.orivenza.com/api/contact
VITE_CONTACT_ENDPOINT=https://api.orivenza.com/api/contact

# Contact mailbox shown in UI fallback links
VITE_CONTACT_EMAIL=get.info@orivenza.com

# Optional dedicated GST demo request endpoint. If blank, CONTACT_ENDPOINT is reused.
VITE_GST_DEMO_REQUEST_ENDPOINT=

# Optional public demo execution endpoint. Leave blank to keep demo execution private.
VITE_GST_DEMO_ENDPOINT=

# AWS-backed GST AI compliance API origin
VITE_GST_AI_COMPLIANCE_ENDPOINT=https://api.orivenza.com

# Remote GST application UI to embed behind the local access gate
VITE_GST_APP_URL=https://gst.orivenza.com/st-ai-compliance

# Base path for subpath hosting (only if not using a custom domain)
# E.g., VITE_BASE=/orivenza-site/ for GitHub Pages project site
# Leave blank or set to / for root domain or custom domain
VITE_BASE=/
