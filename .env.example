# Contact form endpoint (Formspree)
# Create a form at https://formspree.io and set the full endpoint URL here
# E.g., VITE_FORMSPREE_URL=https://formspree.io/f/abc123
VITE_FORMSPREE_URL=

# Contact mailbox shown in UI fallback links
VITE_CONTACT_EMAIL=get.info@orivenza.com

# Base path for subpath hosting (only if not using a custom domain)
# E.g., VITE_BASE=/orivenza-site/ for GitHub Pages project site
# Leave blank or set to / for root domain or custom domain
VITE_BASE=/
